{
  "info": {
    "name": "TaskFlow — Complete Collection",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    {
      "key": "base_url",
      "value": "http://localhost:8080"
    },
    {
      "key": "token",
      "value": ""
    },
    {
      "key": "token2",
      "value": ""
    },
    {
      "key": "project_id",
      "value": ""
    },
    {
      "key": "task_id",
      "value": ""
    }
  ],
  "item": [
    {
      "name": "Auth",
      "item": [
        {
          "name": "Register",
          "request": {
            "method": "POST",
            "url": "{{base_url}}/auth/register",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Nishchay\",\n  \"email\": \"nishchay@test.com\",\n  \"password\": \"password123\"\n}"
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "if (pm.response.code === 201) {",
                  "  pm.collectionVariables.set('token', pm.response.json().token);",
                  "}"
                ]
              }
            }
          ]
        },
        {
          "name": "Login (seed user)",
          "request": {
            "method": "POST",
            "url": "{{base_url}}/auth/login",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"test@example.com\",\n  \"password\": \"password123\"\n}"
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "if (pm.response.code === 200) {",
                  "  pm.collectionVariables.set('token', pm.response.json().token);",
                  "}"
                ]
              }
            }
          ]
        },
        {
          "name": "Register second user",
          "request": {
            "method": "POST",
            "url": "{{base_url}}/auth/register",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Other User\",\n  \"email\": \"other@test.com\",\n  \"password\": \"password123\"\n}"
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "if (pm.response.code === 201) {",
                  "  pm.collectionVariables.set('token2', pm.response.json().token);",
                  "}"
                ]
              }
            }
          ]
        },
        {
          "name": "Register duplicate email (expect 409)",
          "request": {
            "method": "POST",
            "url": "{{base_url}}/auth/register",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Dupe\",\n  \"email\": \"test@example.com\",\n  \"password\": \"password123\"\n}"
            }
          }
        },
        {
          "name": "Login wrong password (expect 401)",
          "request": {
            "method": "POST",
            "url": "{{base_url}}/auth/login",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"test@example.com\",\n  \"password\": \"wrongpassword\"\n}"
            }
          }
        },
        {
          "name": "Register missing fields (expect 400)",
          "request": {
            "method": "POST",
            "url": "{{base_url}}/auth/register",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"incomplete@test.com\"\n}"
            }
          }
        },
        {
          "name": "No token (expect 401)",
          "request": {
            "method": "GET",
            "url": "{{base_url}}/projects"
          }
        },
        {
          "name": "Garbage token (expect 401)",
          "request": {
            "method": "GET",
            "url": "{{base_url}}/projects",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer garbage.token.here"
              }
            ]
          }
        }
      ]
    },
    {
      "name": "Projects",
      "item": [
        {
          "name": "Create project",
          "request": {
            "method": "POST",
            "url": "{{base_url}}/projects",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"TaskFlow Main Project\",\n  \"description\": \"Main test project\"\n}"
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "if (pm.response.code === 201) {",
                  "  pm.collectionVariables.set('project_id', pm.response.json().id);",
                  "}"
                ]
              }
            }
          ]
        },
        {
          "name": "List projects",
          "request": {
            "method": "GET",
            "url": "{{base_url}}/projects",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              }
            ]
          }
        },
        {
          "name": "List projects paginated",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{base_url}}/projects?page=1&limit=5",
              "query": [
                {
                  "key": "page",
                  "value": "1"
                },
                {
                  "key": "limit",
                  "value": "5"
                }
              ]
            },
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              }
            ]
          }
        },
        {
          "name": "List projects page clamping (page=0 limit=500)",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{base_url}}/projects?page=0&limit=500",
              "query": [
                {
                  "key": "page",
                  "value": "0"
                },
                {
                  "key": "limit",
                  "value": "500"
                }
              ]
            },
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              }
            ]
          }
        },
        {
          "name": "Get project",
          "request": {
            "method": "GET",
            "url": "{{base_url}}/projects/{{project_id}}",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              }
            ]
          }
        },
        {
          "name": "Get project not found (expect 404)",
          "request": {
            "method": "GET",
            "url": "{{base_url}}/projects/00000000-0000-0000-0000-000000000000",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              }
            ]
          }
        },
        {
          "name": "Update project",
          "request": {
            "method": "PATCH",
            "url": "{{base_url}}/projects/{{project_id}}",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Updated Project Name\"\n}"
            }
          }
        },
        {
          "name": "Update project empty body (expect no-op 200)",
          "request": {
            "method": "PATCH",
            "url": "{{base_url}}/projects/{{project_id}}",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{}"
            }
          }
        },
        {
          "name": "Update project as non-owner (expect 403)",
          "request": {
            "method": "PATCH",
            "url": "{{base_url}}/projects/{{project_id}}",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "Authorization",
                "value": "Bearer {{token2}}"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Hacked\"\n}"
            }
          }
        },
        {
          "name": "Delete project as non-owner (expect 403)",
          "request": {
            "method": "DELETE",
            "url": "{{base_url}}/projects/{{project_id}}",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{token2}}"
              }
            ]
          }
        },
        {
          "name": "Delete project (expect 204)",
          "request": {
            "method": "DELETE",
            "url": "{{base_url}}/projects/{{project_id}}",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              }
            ]
          }
        }
      ]
    },
    {
      "name": "Tasks",
      "item": [
        {
          "name": "Setup — recreate project",
          "request": {
            "method": "POST",
            "url": "{{base_url}}/projects",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Tasks Test Project\"\n}"
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "if (pm.response.code === 201) {",
                  "  pm.collectionVariables.set('project_id', pm.response.json().id);",
                  "}"
                ]
              }
            }
          ]
        },
        {
          "name": "Create task (expect 201 status=TODO)",
          "request": {
            "method": "POST",
            "url": "{{base_url}}/projects/{{project_id}}/tasks",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"title\": \"Fix login bug\",\n  \"description\": \"Users cant login with uppercase email\",\n  \"priority\": \"HIGH\",\n  \"dueDate\": \"2025-12-31\"\n}"
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "if (pm.response.code === 201) {",
                  "  pm.collectionVariables.set('task_id', pm.response.json().id);",
                  "}"
                ]
              }
            }
          ]
        },
        {
          "name": "Create task missing title (expect 400)",
          "request": {
            "method": "POST",
            "url": "{{base_url}}/projects/{{project_id}}/tasks",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"priority\": \"HIGH\"\n}"
            }
          }
        },
        {
          "name": "Create task as non-owner (expect 403)",
          "request": {
            "method": "POST",
            "url": "{{base_url}}/projects/{{project_id}}/tasks",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "Authorization",
                "value": "Bearer {{token2}}"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"title\": \"Hacked task\"\n}"
            }
          }
        },
        {
          "name": "Create task invalid priority (expect 400)",
          "request": {
            "method": "POST",
            "url": "{{base_url}}/projects/{{project_id}}/tasks",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"title\": \"test\",\n  \"priority\": \"ULTRA\"\n}"
            }
          }
        },
        {
          "name": "List tasks",
          "request": {
            "method": "GET",
            "url": "{{base_url}}/projects/{{project_id}}/tasks",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              }
            ]
          }
        },
        {
          "name": "List tasks paginated",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{base_url}}/projects/{{project_id}}/tasks?page=1&limit=5",
              "query": [
                {
                  "key": "page",
                  "value": "1"
                },
                {
                  "key": "limit",
                  "value": "5"
                }
              ]
            },
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              }
            ]
          }
        },
        {
          "name": "List tasks filter by TODO",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{base_url}}/projects/{{project_id}}/tasks?status=TODO",
              "query": [
                {
                  "key": "status",
                  "value": "TODO"
                }
              ]
            },
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              }
            ]
          }
        },
        {
          "name": "List tasks invalid status (expect 400)",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{base_url}}/projects/{{project_id}}/tasks?status=GARBAGE",
              "query": [
                {
                  "key": "status",
                  "value": "GARBAGE"
                }
              ]
            },
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              }
            ]
          }
        },
        {
          "name": "List tasks page overflow (expect empty data)",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{base_url}}/projects/{{project_id}}/tasks?page=999&limit=20",
              "query": [
                {
                  "key": "page",
                  "value": "999"
                },
                {
                  "key": "limit",
                  "value": "20"
                }
              ]
            },
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              }
            ]
          }
        },
        {
          "name": "Update task status",
          "request": {
            "method": "PATCH",
            "url": "{{base_url}}/tasks/{{task_id}}",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"status\": \"IN_PROGRESS\"\n}"
            }
          }
        },
        {
          "name": "Update task empty body (expect no-op 200)",
          "request": {
            "method": "PATCH",
            "url": "{{base_url}}/tasks/{{task_id}}",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{}"
            }
          }
        },
        {
          "name": "Update task clear assignee",
          "request": {
            "method": "PATCH",
            "url": "{{base_url}}/tasks/{{task_id}}",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"assigneeId\": null\n}"
            }
          }
        },
        {
          "name": "Update task as non-owner non-assignee (expect 403)",
          "request": {
            "method": "PATCH",
            "url": "{{base_url}}/tasks/{{task_id}}",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "Authorization",
                "value": "Bearer {{token2}}"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"status\": \"DONE\"\n}"
            }
          }
        },
        {
          "name": "Update task not found (expect 404)",
          "request": {
            "method": "PATCH",
            "url": "{{base_url}}/tasks/00000000-0000-0000-0000-000000000000",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"status\": \"DONE\"\n}"
            }
          }
        },
        {
          "name": "Delete task as non-owner (expect 403)",
          "request": {
            "method": "DELETE",
            "url": "{{base_url}}/tasks/{{task_id}}",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{token2}}"
              }
            ]
          }
        },
        {
          "name": "Delete task (expect 204)",
          "request": {
            "method": "DELETE",
            "url": "{{base_url}}/tasks/{{task_id}}",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              }
            ]
          }
        },
        {
          "name": "Delete task not found (expect 404)",
          "request": {
            "method": "DELETE",
            "url": "{{base_url}}/tasks/00000000-0000-0000-0000-000000000000",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              }
            ]
          }
        }
      ]
    },
    {
      "name": "Stats",
      "item": [
        {
          "name": "Get project stats",
          "request": {
            "method": "GET",
            "url": "{{base_url}}/projects/{{project_id}}/stats",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              }
            ]
          }
        },
        {
          "name": "Get stats project not found (expect 404)",
          "request": {
            "method": "GET",
            "url": "{{base_url}}/projects/00000000-0000-0000-0000-000000000000/stats",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              }
            ]
          }
        }
      ]
    }
  ]
}