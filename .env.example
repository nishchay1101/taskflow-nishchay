# ─── Database ───────────────────────────────────────────────────────────────
# POSTGRES_HOST: use 'db' for Docker Compose, 'localhost' for local dev
POSTGRES_HOST=db
POSTGRES_PORT=5432
POSTGRES_DB=taskflow
POSTGRES_USER=taskflow
POSTGRES_PASSWORD=taskflow_secret          # change this in production

# ─── JWT ────────────────────────────────────────────────────────────────────
# Generate a strong secret: openssl rand -base64 32
JWT_SECRET=IZLBxAN2q/BckdSyABcspGms0D0yo+wKHb9YPIamuIA=
JWT_EXPIRATION_MS=86400000                 # 24 hours in ms

# ─── Security ───────────────────────────────────────────────────────────────
BCRYPT_STRENGTH=12                         # cost factor: 10=default, 12=production, 4=tests